.venv/

# Heavy render outputs are regenerated each session by snapshot() — keep the
# folder (.gitkeep) but don't version every PNG. Telemetry JSON IS versioned
# (it is the harness's cross-session memory).
50_renders/*.png
50_renders/*.jpg
