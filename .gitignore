# OS
.DS_Store

# Blender backups / temp
*.blend1
*.blend2
*.blend@

# Python
__pycache__/
*.pyc
.venv/

# Third-party addon fetched locally (MIT, ahujasid/blender-mcp) — not re-published here
vendor/

# Reference product images are copyrighted (H&M etc.) and CV debug overlays derived
# from them — kept local, NOT republished. Only derived numeric outlines (data/) are committed.
references/

# Heavy render outputs are regenerated each session by snapshot() — keep the
# folder (.gitkeep) but don't version every PNG. Telemetry JSON IS versioned
# (it is the harness's cross-session memory).
50_renders/*.png
50_renders/*.jpg
